# CampConnect Backend - Environment Configuration
# Copy this file to .env and fill in your real values
# NEVER commit .env to git - it contains sensitive secrets

# ============================================
# APP CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=production

# ============================================
# DATABASE - MongoDB Atlas
# ============================================
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://your_username:your_password@your-cluster.mongodb.net/campconnect?retryWrites=true&w=majority

# ============================================
# SECURITY
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_64_character_random_hex_string_for_jwt_signing_secret_here

# ============================================
# REDIS - For session tracking and caching
# ============================================
# Local: redis://localhost:6379
# Remote (Upstash, etc.): redis://:password@hostname:port
REDIS_URL=redis://localhost:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ============================================
# FRONTEND CORS
# ============================================
# Allowed origin for frontend requests (production URL)
FRONTEND_PRODUCTION_URL=https://your-frontend-domain.com

# ============================================
# ADMIN CONTACT
# ============================================
ADMIN_EMAIL=admin@campconnect.local

# ============================================
# OPTIONAL: Email Service (if implementing password reset emails)
# ============================================
# EMAIL_SERVICE=gmail
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password

# ============================================
# OPTIONAL: File Storage (if implementing S3 uploads)
# ============================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# S3_BUCKET=your-bucket-name
